  "schema:identifier": "XA-ICH-002",
  "schema:name": "华阴老腔",
  "schema:description": "华阴老腔是流传于陕西省华阴市双泉村的一种皮影戏曲声腔，被誉为「中国最古老的摇滚乐」。其唱腔高亢激昂、气势磅礴，伴奏以月琴、板胡和独特的长凳击打为特色。2006年被列入首批国家级非物质文化遗产名录。2016年登上央视春晚后走红全国，成为跨界融合的传统文化创新典范。",
  "schema:keywords": [
    "传统戏剧",
    "皮影戏声腔",
    "月琴",
    "汉代漕运号子",
    "春晚",
    "跨界融合"
  ],
  "cultural:culturalElements": {
