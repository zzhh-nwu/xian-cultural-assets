  "schema:identifier": "SA-YA-TOUR-001",
  "schema:name": "壶口瀑布",
  "schema:description": "壶口瀑布，世界最大的金黄色瀑布，被誉为\"黄河魂所在地\"。位于陕西省延安市，黄河在此奔流直下，形成壮观的瀑布景观，象征中华民族的坚韧与力量。数字化方面，已完成瀑布三维建模和黄河文化VR沉浸式体验，游客可身临其境感受黄河的磅礴气势。",
  "schema:keywords": [
    "壶口瀑布",
    "黄河魂",
    "金黄色瀑布",
    "三维建模",
    "VR体验"
  ],
