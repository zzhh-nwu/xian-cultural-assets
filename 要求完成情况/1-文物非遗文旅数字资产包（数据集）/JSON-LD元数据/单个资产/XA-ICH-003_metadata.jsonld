  "schema:identifier": "XA-ICH-003",
  "schema:name": "陕西皮影戏",
  "schema:description": "陕西皮影戏是中国皮影艺术的重要流派，以华县皮影最具代表性，2011年被列入人类非物质文化遗产代表作名录。陕西皮影雕刻工艺精湛，以牛皮为材，经选皮、制皮、画稿、雕刻、敷色、熨平、缀结等二十余道工序完成，是集绘画、雕刻、表演、音乐于一体的综合艺术。",
  "schema:keywords": [
    "传统戏剧",
    "皮影",
    "雕刻",
    "牛皮",
    "华县",
    "UNESCO非遗",
    "综合艺术"
  ],
  "cultural:culturalElements": {
    "cultural:period": "起源于汉代，成熟于唐宋，繁荣于明清",
    "cultural:material": "秦川牛皮 + 矿物/植物染料 + 丝线",
    "cultural:technique": "选皮-制皮-画稿-雕刻（推皮走刀技法）-敷色-熨平-缀结，共二十余道工序",
    "cultural:iconography": "影人造型：五分面/七分面、武将/旦角/丑角等类别；纹样：雪花纹、万字纹、梅花纹等",
    "cultural:style": "陕西东路皮影精细华美、西路皮影粗犷豪放",
    "cultural:function": "民间戏剧演出、历史故事传播、祭祀酬神"
  },
