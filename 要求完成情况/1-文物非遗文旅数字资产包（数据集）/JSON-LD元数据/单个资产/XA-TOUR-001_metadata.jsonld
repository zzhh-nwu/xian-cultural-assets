    "cultural:material": "外壁青砖包砌 + 内壁夯土 + 垛口砖石",
    "cultural:technique": "砖石砌筑、包砖工艺、夯土芯体、瓮城防御工事",
    "cultural:iconography": "方形古城格局、城门四向对称、垛口整齐排列",
    "cultural:style": "明代军事防御建筑风格",
    "cultural:function": "城市防御 + 现代文旅体验"
  },
