  "schema:identifier": "XA-TOUR-002",
  "schema:name": "大唐不夜城",
  "schema:description": "大唐不夜城位于西安市雁塔区大雁塔脚下，是以盛唐文化为主题的大型商业步行街和国家级夜间文旅消费集聚区。不倒翁小姐姐等创新IP现象级走红，使大唐不夜城成为西安文旅新名片和中国夜间经济的标杆。",
  "schema:keywords": [
    "盛唐文化",
    "商业步行街",
    "夜间经济",
    "不倒翁",
    "大雁塔",
    "网红打卡",
    "沉浸式",
    "国风"
  ],
  "cultural:culturalElements": {
    "cultural:period": "现代（2010年开街），文化主题为唐代（618-907年）",
    "cultural:material": "",
    "cultural:technique": "唐风建筑群（仿古）+ 现代商业综合体 + 灯光秀 + 行为艺术 + 沉浸式演艺",
    "cultural:iconography": "盛唐主题雕塑群、唐风灯饰、辇车花车、唐装巡游",
    "cultural:style": "唐风与现代商业的融合风格",
    "cultural:function": "文化旅游体验 + 夜间消费 + 城市品牌传播"
  },
